@article{Polman2025,
  author    = {Daniel Polman and Liesbeth de Schutter and Stephanie Begemann and Jose D. Lopez-Rivas and Eveline van Leeuwen and Joana Wensing},
  title     = {Cities in the loop: A social science perspective on the role of cities in food system circularity},
  journal   = {Regional Science Policy and Practice},
  volume    = {17},
  year      = {2025},
  doi       = {10.1016/j.rspp.2025.100238},
  html      = {https://doi.org/10.1016/j.rspp.2025.100238},
  abbr      = {RSPP},
  abstract  = {The transition to a circular food system is crucial to address the environmental pressures, inefficiencies, and socioeconomic inequalities inherent in linear food systems. Cities as dense population hubs possess considerable potential in steering food provisioning systems from a consumption perspective. This paper explores social science approaches to understanding if and how cities can drive and scale food system transitions on the basis of circular principles and practices.},
  selected  = {false}
}

@article{LopezRivas2024water,
  author    = {Jos{'\e} D. L{'\o}pez-Rivas},
  title     = {Spreading the word! {E}ffects of a randomized normative informational campaign on residential water conservation},
  journal   = {Resource and Energy Economics},
  volume    = {79--80},
  pages     = {101463},
  year      = {2024},
  doi       = {10.1016/j.reseneeco.2024.101463},
  html      = {https://doi.org/10.1016/j.reseneeco.2024.101463},
  abbr      = {REE},
  abstract  = {This paper reports the direct and spillover effects of a norm-based informational campaign on residential water usage. Using a two-stage randomized saturation design, I find targeted and spillover households reduced their water usage compared to the control group, with average reductions of 8.2% and 5.6%, respectively. The findings shed light on the efficacy of leveraging social influence and norms to foster environmentally responsible behaviors.},
  keywords  = {Pro-environmental behavior, Randomized control trial, Social norms, Spillover effects},
  selected  = {true}
}

@article{LopezRivas2024marine,
  author    = {Jose D. Lopez-Rivas and Juan Camilo Cardenas},
  title     = {What is the economic value of coastal and marine ecosystem services? {A} systematic literature review},
  journal   = {Marine Policy},
  volume    = {161},
  pages     = {106033},
  year      = {2024},
  doi       = {10.1016/j.marpol.2024.106033},
  html      = {https://doi.org/10.1016/j.marpol.2024.106033},
  abbr      = {Mar. Policy},
  abstract  = {This paper examines the economic value of marine and coastal ecosystem services by analyzing 67 studies published in scientific literature. The studies focus on ecosystem services provided by coral reefs, marine waters, and mangrove forests. Findings inform policy discussions about preserving these valuable ecosystems in the context of the climate crisis.},
  keywords  = {Coastal and marine ecosystems, Economic valuation, Ecosystem services, Meta-analysis, Systematic review},
  selected  = {true}
}

@article{Wensing2024,
  author    = {Joana Wensing and Daniel Polman and Jose D. Lopez-Rivas and Roger Cremades and Eveline Van Leeuwen},
  title     = {Green {M}eal? {T}he role of situational contexts for real-time vegetarian meal choices},
  journal   = {Journal of Environmental Psychology},
  volume    = {98},
  pages     = {102403},
  year      = {2024},
  doi       = {10.1016/j.jenvp.2024.102403},
  html      = {https://doi.org/10.1016/j.jenvp.2024.102403},
  abbr      = {JEP},
  abstract  = {This study applies ecological momentary assessment over three subsequent weeks with 82 participants and 1449 daily meal choices. Results indicate that individuals are much more likely to eat vegetarian when others in their company also eat a vegetarian meal, highlighting the role of social context in dietary choices.},
  keywords  = {Context, Ecological momentary assessment, Food, Meat consumption, Mood, Situation},
  selected  = {false}
}

@unpublished{Jensen2025,
  author      = {Nathaniel D. Jensen and Jose D. Lopez-Rivas and Karlijn Morsink and Emma E. Rikken},
  title       = {Weathering conflict: the effect of resource shocks on livestock raids},
  year        = {2025},
  institution = {University of Oxford},
  note        = {CSAE Working Paper},
  html        = {https://ora.ox.ac.uk/objects/uuid:ec327279-68d9-484a-a5f5-7bdecfa26def},
  abbr        = {WP},
  abstract    = {We examine the impact of climate shocks and drought insurance on inter-communal pastoral conflict in Kenya and Ethiopia. Using NASA's eMODIS satellite data and a 40-season longitudinal household dataset, we find that negative shocks increase conflict in dry seasons, while positive shocks fuel conflict in subsequent rainy seasons. We also find that while insurance reduces conflict on average, ex ante insurance coverage exacerbates conflict when pasture is abundant.},
  selected    = {true}
}

@unpublished{LopezRivas2024elnino,
  author      = {Jose D. Lopez-Rivas and D. Le{\'o}n},
  title       = {El {N}i{\~n}o is {C}oming: {A}ssessing the {I}mpact of {F}ine-{B}ased {P}olicy on {C}ollective {A}ction in {A}nticipation of a {D}rought in {C}olombia},
  year        = {2024},
  note        = {Working Paper},
  pdf         = {https://www.josedavidlopezrivas.com/_files/ugd/1b970b_90847913fc4843b98045ae32c9b31c56.pdf},
  abbr        = {WP},
  abstract    = {This paper evaluates whether a fine-based regulatory policy activates collective action in water conservation when communities face an anticipated climate shock. Using quasi-experimental variation generated by the announcement of an El Niño event in Colombia, we examine how the threat of enforcement interacts with community-level cooperation incentives.},
  selected    = {true}
}